generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["api-service"]
}

// ENUMS - START

enum HazardType {
  floods
  drought
  tropicalCyclone

  @@schema("api-service")
}

enum AlertClass {
  low
  medium
  high

  @@schema("api-service")
}

enum EnsembleMemberType {
  median
  run

  @@schema("api-service")
}

enum ForecastSource {
  glofas
  ECMWF
  gefs

  @@schema("api-service")
}

enum SeverityKey {
  returnPeriod
  percentile
  windSpeed

  @@schema("api-service")
}

enum AlertClassificationLevel {
  singleThreshold
  low
  medium
  high

  @@schema("api-service")
}

enum LayerName {
  population
  populationExposed
  redCrossBranches
  clinics
  floodDepth
  glofasStations
  windSpeed

  @@schema("api-service")
}

enum LayerType {
  raster
  shape
  point
  vectorTile

  @@schema("api-service")
}

// ENUMS - END

// MODELS - START

model User {
  @@schema("api-service")
  @@map("user")

  id          Int      @id @default(autoincrement())
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  username    String?   @unique
  password    String
  admin       Boolean  @default(false)
  salt        String?
  lastLogin   DateTime?
  displayName String

  @@index([created])
  @@index([username])
}

model Alert {
  @@schema("api-service")
  @@map("alert")

  id              Int      @id @default(autoincrement())
  created         DateTime @default(now())
  updated         DateTime @updatedAt
  eventName       String
  issuedAt        DateTime
  centroid        Json
  hazardType      HazardType
  forecastSources ForecastSource[]
  eventId         Int?
  event           Event?   @relation(fields: [eventId], references: [id])

  severity             AlertSeverity[]
  exposureAdminArea    AlertExposureAdminArea[]
  exposureGeoFeature   AlertExposureGeoFeature[]
  exposureRasterData   AlertExposureRasterData[]

  @@index([eventId])
}

model Event {
  @@schema("api-service")
  @@map("event")

  id                        Int       @id @default(autoincrement())
  created                   DateTime  @default(now())
  updated                   DateTime  @updatedAt
  eventName                 String
  hazardType                HazardType
  forecastSources           ForecastSource[]
  alertClass                AlertClass
  trigger                   Boolean
  centroid                  Json
  startAt                   DateTime
  reachesPeakAlertClassAt   DateTime
  endAt                     DateTime
  firstIssuedAt             DateTime
  lastUpdatedAt             DateTime
  closedAt                  DateTime?

  alerts                    Alert[]

  @@index([eventName])
}

model AlertSeverity {
  @@schema("api-service")
  @@map("alert-severity")

  id                 Int      @id @default(autoincrement())
  created            DateTime @default(now())
  updated            DateTime @updatedAt
  alertId            Int
  alert              Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  timeInterval       Json
  ensembleMemberType EnsembleMemberType
  severityKey        SeverityKey
  severityValue      Float

  @@index([alertId])
}

model AlertExposureAdminArea {
  @@schema("api-service")
  @@map("alert-exposure-admin-area")

  id         Int      @id @default(autoincrement())
  created    DateTime @default(now())
  updated    DateTime @updatedAt
  alertId    Int
  alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  placeCode  String
  adminLevel Int
  layer      LayerName
  value      Float

  @@index([alertId])
  @@index([alertId, adminLevel])
}

model AlertExposureGeoFeature {
  @@schema("api-service")
  @@map("alert-exposure-geo-features")

  id           Int      @id @default(autoincrement())
  created      DateTime @default(now())
  updated      DateTime @updatedAt
  alertId      Int
  alert        Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  geoFeatureId String
  layer        LayerName
  attributes   Json

  @@index([alertId])
}

model AlertExposureRasterData {
  @@schema("api-service")
  @@map("alert-exposure-raster-data")

  id              Int      @id @default(autoincrement())
  created         DateTime @default(now())
  updated         DateTime @updatedAt
  alertId         Int
  alert           Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  layer           LayerName
  valueGreyscale  String
  valueColoured   String
  metadata        Json

  @@index([alertId])
}

model StaticRasterData {
  @@schema("api-service")
  @@map("static-raster-data")

  id              Int      @id @default(autoincrement())
  created         DateTime @default(now())
  updated         DateTime @updatedAt
  countryCodeIso3 String
  country         Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  layer           LayerName
  valueData       String
  valueColoured   String
  metadata        Json

  @@unique([countryCodeIso3, layer])
  @@index([countryCodeIso3])
}

model Country {
  @@schema("api-service")
  @@map("country")

  id               Int      @id @default(autoincrement())
  created          DateTime @default(now())
  updated          DateTime @updatedAt
  countryCodeIso3  String   @unique
  countryCodeIso2  String
  countryName      String

  adminAreas       AdminArea[]
  alertConfigs     AlertConfig[]
  geoFeatures      GeoFeature[]
  staticRasterData StaticRasterData[]
}

model AdminArea {
  @@schema("api-service")
  @@map("admin-area")

  id                Int      @id @default(autoincrement())
  created           DateTime @default(now())
  updated           DateTime @updatedAt
  placeCode         String   @unique
  adminLevel        Int
  nameEn            String
  countryCodeIso3   String
  country           Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  placeCodeLevel1   String?
  placeCodeLevel2   String?
  placeCodeLevel3   String?
  placeCodeLevel4   String?
  attributes        Json   @default("{}") // e.g. { "POPULATION": 215293 }
  geometry          Unsupported("geometry(MultiPolygon, 4326)")?

  @@index([countryCodeIso3])
  @@index([countryCodeIso3, adminLevel])
}

model GeoFeature {
  @@schema("api-service")
  @@map("geo-feature")

  id              Int      @id @default(autoincrement())
  created         DateTime @default(now())
  updated         DateTime @updatedAt
  countryCodeIso3 String
  country         Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  featureType     String // Point, LineString, Polygon, MultiPolygon
  layer           LayerName // e.g. "glofasStations"
  referenceId     String // external identifier, e.g. station code
  geometry        Unsupported("geometry(Geometry, 4326)")?
  attributes      Json   @default("{}")

  @@unique([countryCodeIso3, layer, referenceId])
  @@index([countryCodeIso3, layer])
}

model AlertConfig {
  @@schema("api-service")
  @@map("alert-config")

  id                        Int      @id @default(autoincrement())
  created                   DateTime @default(now())
  updated                   DateTime @updatedAt
  countryCodeIso3           String
  country                   Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  hazardType                HazardType
  spatialExtentName         String
  spatialExtentPlaceCodes   String[] // soft FK to admin-area.placeCode
  temporalExtents           Json
  severityClassLevels       Json
  // TODO: the classification fields below are currently duplicated per row (they are hazard-type-level, not per-station). Handle differently later.
  probabilityClassLevels    Json
  triggerAlertClass         AlertClass?
  triggerLeadTimeDuration   String?

  @@index([countryCodeIso3])
  @@index([countryCodeIso3, hazardType])
}

// MODELS - END
