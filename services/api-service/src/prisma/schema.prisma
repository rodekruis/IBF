generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["api-service"]
}

model User {
  @@schema("api-service")
  @@map("user")

  id          Int      @id @default(autoincrement())
  created     DateTime @default(now())
  updated     DateTime @updatedAt

  username    String?   @unique
  password    String
  admin       Boolean  @default(false)
  salt        String?
  lastLogin   DateTime?
  displayName String

  @@index([created])
  @@index([username])
}

model Alert {
  @@schema("api-service")
  @@map("alert")

  id              Int      @id @default(autoincrement())
  created         DateTime @default(now())
  updated         DateTime @updatedAt
  eventName       String
  issuedAt        DateTime
  centroid        Json
  hazardType      String
  forecastSources String[]
  eventId         Int?
  event           Event?   @relation(fields: [eventId], references: [id])

  severity             AlertSeverity[]
  exposureAdminArea    AlertExposureAdminArea[]
  exposureGeoFeature   AlertExposureGeoFeature[]
  exposureRasterData   AlertExposureRasterData[]

  @@index([eventId])
}

model Event {
  @@schema("api-service")
  @@map("event")

  id                        Int       @id @default(autoincrement())
  created                   DateTime  @default(now())
  updated                   DateTime  @updatedAt
  eventName                 String
  hazardType                String
  forecastSources           String[]
  alertClass                String
  trigger                   Boolean
  centroid                  Json
  startAt                   DateTime
  reachesPeakAlertClassAt   DateTime
  endAt                     DateTime
  firstIssuedAt             DateTime
  lastUpdatedAt             DateTime
  closedAt                  DateTime?

  alerts                    Alert[]

  @@index([eventName])
}

model AlertSeverity {
  @@schema("api-service")
  @@map("alert-severity")

  id                 Int      @id @default(autoincrement())
  created            DateTime @default(now())
  updated            DateTime @updatedAt
  alertId            Int
  alert              Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  timeInterval       Json
  ensembleMemberType String
  severityKey        String
  severityValue      Float

  @@index([alertId])
}

model AlertExposureAdminArea {
  @@schema("api-service")
  @@map("alert-exposure-admin-area")

  id         Int      @id @default(autoincrement())
  created    DateTime @default(now())
  updated    DateTime @updatedAt
  alertId    Int
  alert      Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  placeCode  String
  adminLevel Int
  layer      String
  value      Float

  @@index([alertId])
  @@index([alertId, adminLevel])
}

model AlertExposureGeoFeature {
  @@schema("api-service")
  @@map("alert-exposure-geo-features")

  id           Int      @id @default(autoincrement())
  created      DateTime @default(now())
  updated      DateTime @updatedAt
  alertId      Int
  alert        Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  geoFeatureId String
  layer        String
  attributes   Json

  @@index([alertId])
}

model AlertExposureRasterData {
  @@schema("api-service")
  @@map("alert-exposure-raster-data")

  id      Int      @id @default(autoincrement())
  created DateTime @default(now())
  updated DateTime @updatedAt
  alertId Int
  alert   Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  layer   String
  value   String
  extent  Json

  @@index([alertId])
}

model Country {
  @@schema("api-service")
  @@map("country")

  id               Int      @id @default(autoincrement())
  created          DateTime @default(now())
  updated          DateTime @updatedAt
  countryCodeIso3  String   @unique
  countryCodeIso2  String
  countryName      String

  adminAreas       AdminArea[]
  alertConfigs     AlertConfig[]
}

model AdminArea {
  @@schema("api-service")
  @@map("admin-area")

  id                Int      @id @default(autoincrement())
  created           DateTime @default(now())
  updated           DateTime @updatedAt
  placeCode         String   @unique
  adminLevel        Int
  nameEn            String
  countryCodeIso3   String
  country           Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  parentPlaceCode   String? // soft FK to admin-area.placeCode
  // TODO: pg_featureserv cannot discover this table yet because it stores geometry as JSONB and/or because it cannot read the 'api-service' schema it seems.
  // To fix, either change to a real PostGIS geometry column or create a SQL view that casts JSONB to geometry.
  geometry          Json

  @@index([countryCodeIso3])
  @@index([countryCodeIso3, adminLevel])
}

model AlertConfig {
  @@schema("api-service")
  @@map("alert-config")

  id                        Int      @id @default(autoincrement())
  created                   DateTime @default(now())
  updated                   DateTime @updatedAt
  countryCodeIso3           String
  country                   Country  @relation(fields: [countryCodeIso3], references: [countryCodeIso3])
  hazardType                String
  spatialExtentName         String
  spatialExtentPlaceCodes   String[] // soft FK to admin-area.placeCode
  temporalExtents           Json
  severityClassLevels       Json
  // TODO: the classification fields below are currently duplicated per row (they are hazard-type-level, not per-station). Handle differently later.
  probabilityClassLevels    Json
  alertClassMatrix          Json
  alertClassOrder           String[]
  triggerAlertClass         String?
  triggerLeadTimeDuration   String?

  @@index([countryCodeIso3])
  @@index([countryCodeIso3, hazardType])
}
