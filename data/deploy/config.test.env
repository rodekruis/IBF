# Azure deploy config for the TEST environment.
# Override any of these in your shell before running ./deploy/deploy.sh

AZURE_ENV_NAME="test"
AZURE_LOCATION="westeurope"

RESOURCE_GROUP="nrw-pipelines-${AZURE_ENV_NAME}-rg"
LOG_ANALYTICS_NAME="nrw-pipelines-${AZURE_ENV_NAME}-logs"
CONTAINER_APPS_ENV="nrw-pipelines-${AZURE_ENV_NAME}-env"
# ACR names must be 5-50 lowercase alphanumerics, globally unique.
ACR_NAME="nrwpipelines${AZURE_ENV_NAME}acr"
ACTION_GROUP_NAME="nrw-pipelines-${AZURE_ENV_NAME}-ag"
ACTION_GROUP_SHORT="nrwpipes"
ALERT_RULE_NAME="nrw-pipelines-${AZURE_ENV_NAME}-failures"

ALERT_EMAIL="ehill@redcross.nl"

IMAGE_NAME="nrw-pipelines"
IMAGE_TAG="latest"

# Path (inside repo) to the .env file with pipeline secrets.
ENV_FILE="./.env"

# Cron schedules (UTC). Stagger to avoid overlap.
DROUGHT_CRON="0 6 * * *"
FLOODS_CRON="15 6 * * *"

DROUGHT_RUN_TARGET="DEBUG"
FLOODS_RUN_TARGET="DEBUG"

# Job runtime caps.
REPLICA_TIMEOUT_SECONDS="3600"
REPLICA_RETRY_LIMIT="1"

# Container resources.
CPU="1.0"
MEMORY="2.0Gi"

# Tags applied to every Azure resource created by deploy.sh.
# Use these to filter in the Azure Portal ("All resources" -> Filter -> Tags).
TAG_PROJECT="erik-nrw-pipelines"
TAG_ENV="${AZURE_ENV_NAME}"
TAG_OWNER="ehill@redcross.nl"
TAG_MANAGED_BY="deploy.sh"
