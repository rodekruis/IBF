{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "es2023",
        "lib": ["ES2023", "DOM"],
        "module": "esnext",
        "types": ["vite/client"],
        "skipLibCheck": true,

        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",

        /* Linting */
        "noUnusedLocals": true,
        /* Disabled: the go-web-app submodule currently has unused params that
           pass there (probably because Vite skips tsc). Once resolved upstream, re-enable. */
        "noUnusedParameters": false,
        "erasableSyntaxOnly": false,
        "noFallthroughCasesInSwitch": true,

        "paths": {
            "#utils/*": ["./src/go-web-app/app/src/utils/*"],
            "#hooks/*": ["./src/hooks/*"],
            "#components/*": ["./src/go-web-app/app/src/components/*"],
            "#config": ["./src/utils/envParser.ts"],
            "#base": ["./src/main.tsx"]
        }
    },
    "include": ["src"]
}
