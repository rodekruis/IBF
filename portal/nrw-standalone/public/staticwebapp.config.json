{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.{js,json,css,map,jpg,jpeg,png,svg,ico,webmanifest,woff,woff2,txt}"
    ]
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "immutable, no-transform, max-age=31536000"
      }
    }
  ],
  "trailingSlash": "auto",
  "globalHeaders": {
    "Cross-Origin-Opener-Policy": "same-origin",
    "Permissions-Policy": "document-domain=(), storage-access=(self), attribution-reporting=(), interest-cohort=(), browsing-topics=()",
    "Referrer-Policy": "same-origin",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  }
}
