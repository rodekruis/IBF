# Rename this file to .env to use it.

# App title so it's easy to identify your build
APP_TITLE="DEV GO"

# Can be development, staging, production, etc. See env.ts for options.
APP_ENVIRONMENT=development

# GO backend
# For non-Montandon data: DREF, reports, stats, etc.
APP_API_ENDPOINT=http://localhost:8000/api/ # this is a guess. We can't run it yet

# API Keys (used in app)
APP_MAPBOX_ACCESS_TOKEN=__fake__key____
APP_TINY_API_KEY=__fake__key____

# API Keys (used for build)
FONTAWESOME_API_KEY=__fake__key____

# Montandon (I think)
# Must be an external url
APP_RISK_API_ENDPOINT=https://secret.wow.yes.com/api/

# IBF API backend
APP_IBF_API_BACKEND=http://localhost:4000/api/

# NRW portal hosting mode
# Set to STANDALONE for the NRW standalone settings
# Any other setting will default to nested mode (format when in GO portal)
APP_NRW_PORTAL_MODE=NESTED
